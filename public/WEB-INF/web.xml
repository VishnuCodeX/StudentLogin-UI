<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!--
      React Router client-side routing fallback. Tomcat has no equivalent of Nginx's
      try_files — a direct hit or refresh on a client route (e.g. /CarmelNexus/dashboard)
      has no matching file/servlet and 404s. Route every 404 back to index.html so
      BrowserRouter can take over and resolve the path itself.
    -->
    <error-page>
        <error-code>404</error-code>
        <location>/index.html</location>
    </error-page>

</web-app>
